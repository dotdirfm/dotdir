{
  "name": "faraday-tauri",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "serve:web": "pnpm build && cargo run --manifest-path src-tauri/Cargo.toml -- serve --host 127.0.0.1 --port 3001",
    "serve:web:release": "pnpm build && cargo run --release --manifest-path src-tauri/Cargo.toml -- serve --host 127.0.0.1 --port 3001",
    "build:rust": "cd src-tauri && cargo build --release",
    "build:rust:dev": "cd src-tauri && cargo build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-css": "^6.2.1",
    "@codemirror/lang-html": "^6.4.7",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.3",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.5.6",
    "@codemirror/lang-xml": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fss-lang": "^0.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "~5.9.3",
    "vite": "^7.0.4"
  },
  "packageManager": "pnpm@10.30.3"
}
