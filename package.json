{
  "name": "faraday",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "serve:web": "pnpm build && cargo run --manifest-path src-tauri/Cargo.toml -- serve --host 127.0.0.1 --port 3001",
    "serve:web:release": "pnpm build && cargo run --release --manifest-path src-tauri/Cargo.toml -- serve --host 127.0.0.1 --port 3001",
    "build:rust": "cd src-tauri && cargo build --release",
    "build:rust:dev": "cd src-tauri && cargo build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1",
    "fss-lang": "^0.0.5",
    "jsonc-parser": "^3.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vscode-oniguruma": "^2.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
