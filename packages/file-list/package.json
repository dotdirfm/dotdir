{
  "name": "@dotdirfm/file-list",
  "version": "0.1.0",
  "description": "Reusable DotDir file list component for React apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    },
    "./file-list.css": {
      "import": "./dist/file-list.css"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "dotdir",
    "file-manager",
    "react",
    "ui"
  ],
  "author": "Mikhail Isupov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotdirfm/dotdir.git"
  },
  "homepage": "https://github.com/dotdirfm/dotdir#readme",
  "bugs": {
    "url": "https://github.com/dotdirfm/dotdir/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@dotdirfm/commands": "workspace:*",
    "@dotdirfm/fss-lang": "workspace:*",
    "@dotdirfm/ui-utils": "workspace:*"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@tsdown/css": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
