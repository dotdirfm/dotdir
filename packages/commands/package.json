{
  "name": "@dotdirfm/commands",
  "version": "0.1.0",
  "description": "Shared command registry and keybinding primitives for DotDir.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    },
    "./commandIds": {
      "import": "./dist/commandIds.mjs",
      "require": "./dist/commandIds.cjs",
      "types": "./dist/commandIds.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "dotdir",
    "commands",
    "keybindings"
  ],
  "author": "Mikhail Isupov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotdirfm/dotdir.git"
  },
  "homepage": "https://github.com/dotdirfm/dotdir#readme",
  "bugs": {
    "url": "https://github.com/dotdirfm/dotdir/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@dotdirfm/ui-utils": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.17.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.30.3"
}
