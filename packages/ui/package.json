{
  "name": "@dotdirfm/ui",
  "version": "0.1.34",
  "description": "Reusable DotDir file manager UI component for React apps.",
  "main": "./dist/dotdir.js",
  "module": "./dist/dotdir.mjs",
  "types": "./dist/lib/DotDir.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/dotdir.mjs",
      "require": "./dist/dotdir.js",
      "types": "./dist/lib/DotDir.d.ts"
    },
    "./dotdir.css": {
      "import": "./dist/dotdir.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "pnpm --filter @dotdirfm/commands build && pnpm --filter fss-lang build && pnpm --filter @dotdirfm/extension-api build && tsc && vite build",
    "lint": "eslint lib vite.config.ts",
    "lint:fix": "eslint lib vite.config.ts --fix",
    "fmt": "eslint lib vite.config.ts --fix",
    "fmt:check": "eslint lib vite.config.ts --fix-dry-run",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "keywords": [
    "dotdir",
    "file-manager",
    "react",
    "ui",
    "terminal"
  ],
  "author": "Mikhail Isupov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotdirfm/dotdir.git"
  },
  "homepage": "https://github.com/dotdirfm/dotdir#readme",
  "bugs": {
    "url": "https://github.com/dotdirfm/dotdir/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@dotdirfm/commands": "workspace:*",
    "@dotdirfm/extension-api": "workspace:*",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fss-lang": "workspace:*",
    "jotai": "^2.19.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^17.0.5",
    "monaco-editor": "^0.55.1",
    "react-icons": "^5.6.0",
    "semver": "^7.7.4",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.3"
}
