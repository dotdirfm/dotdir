{
  "name": "@dotdirfm/ui",
  "version": "0.1.34",
  "description": "Reusable DotDir file manager UI component for React apps.",
  "main": "./dist/dotdir.js",
  "module": "./dist/dotdir.mjs",
  "types": "./dist/lib/DotDir.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/dotdir.mjs",
      "require": "./dist/dotdir.js",
      "types": "./dist/lib/DotDir.d.ts"
    },
    "./dotdir.css": {
      "import": "./dist/dotdir.css"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "eslint lib vite.config.ts",
    "lint:fix": "eslint lib vite.config.ts --fix",
    "fmt": "eslint lib vite.config.ts --fix",
    "fmt:check": "eslint lib vite.config.ts --fix-dry-run",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "keywords": [
    "dotdir",
    "file-manager",
    "react",
    "ui",
    "terminal"
  ],
  "author": "Mikhail Isupov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotdirfm/dotdir.git"
  },
  "homepage": "https://github.com/dotdirfm/dotdir#readme",
  "bugs": {
    "url": "https://github.com/dotdirfm/dotdir/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@dotdirfm/commands": "workspace:*",
    "@dotdirfm/extension-api": "workspace:*",
    "@dotdirfm/file-list": "workspace:*",
    "@dotdirfm/fss": "workspace:*",
    "@dotdirfm/terminal": "workspace:*",
    "@dotdirfm/ui-bridge": "workspace:*",
    "@dotdirfm/ui-focus": "workspace:*",
    "@dotdirfm/ui-utils": "workspace:*",
    "@tanstack/react-virtual": "catalog:",
    "jotai": "catalog:",
    "jsonc-parser": "catalog:",
    "marked": "catalog:",
    "monaco-editor": "catalog:",
    "react-icons": "catalog:",
    "semver": "catalog:",
    "vscode-oniguruma": "catalog:",
    "vscode-textmate": "catalog:"
  },
  "devDependencies": {
    "@types/semver": "catalog:",
    "vite": "^8.0.0",
    "vite-plugin-dts": "catalog:",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.3"
}
