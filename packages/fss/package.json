{
  "name": "@dotdirfm/fss",
  "type": "module",
  "version": "0.0.6",
  "description": "File Style Sheets — a CSS-like language for describing how files should be rendered in a tree or panel.",
  "author": "Mikhail Isupov <lam0x86@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/dotdirfm/dotdir#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotdirfm/dotdir.git"
  },
  "bugs": {
    "url": "https://github.com/dotdirfm/dotdir/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./helpers": {
      "types": "./dist/helpers.d.mts",
      "import": "./dist/helpers.mjs",
      "require": "./dist/helpers.cjs",
      "default": "./dist/helpers.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/css-tree": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "css-tree": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3"
}
